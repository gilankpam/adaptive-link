# ─── Configuration helpers ───────────────────────────────────────────────────

def create_default_config(config_file):
    target = os.path.realpath(config_file) if os.path.islink(config_file) else config_file
    try:
        with open(target, 'w') as f:
            f.write(DEFAULT_CONFIG)
        print(f"Created default config file at {target}")
    except Exception as e:
        print(f"Error writing default config file: {e}")


def load_configuration(config_file):
    config = configparser.ConfigParser()
    read_files = config.read(config_file)
    if not read_files or not REQUIRED_SECTIONS.issubset(set(config.sections())):
        print("Configuration file missing or invalid. Creating default configuration...")
        create_default_config(config_file)
        config.read(config_file)
    return config


# ─── Profile loading ─────────────────────────────────────────────────────────

def load_profiles(filename):
    """Load TX profiles from txprofiles.conf format.

    Each line: rangeMin - rangeMax GI MCS FecK FecN Bitrate GOP Power ROIqp Bandwidth QpDelta
    """
    profiles = []
    try:
        with open(filename) as f:
            for line in f:
                line = line.split('#')[0].strip()
                if not line:
                    continue
                parts = line.split()
                if len(parts) < 12 or parts[1] != '-':
                    continue
                profiles.append({
                    'range_min': int(parts[0]),
                    'range_max': int(parts[2]),
                    'gi': parts[3],
                    'mcs': int(parts[4]),
                    'fec_k': int(parts[5]),
                    'fec_n': int(parts[6]),
                    'bitrate': int(parts[7]),
                    'gop': float(parts[8]),
                    'power': int(parts[9]),
                    'roi_qp': parts[10],
                    'bandwidth': int(parts[11]),
                    'qp_delta': int(parts[12]) if len(parts) > 12 else 0,
                })
    except FileNotFoundError:
        print(f"Error: Profiles file not found: {filename}")
    return profiles


# ─── Kalman filter ────────────────────────────────────────────────────────────

class KalmanFilter:
    def __init__(self, estimate, error_estimate, process_variance, measurement_variance):
        self.estimate = estimate
        self.error_estimate = error_estimate
        self.process_variance = process_variance
        self.measurement_variance = measurement_variance

    def update(self, measurement):
        predicted_estimate = self.estimate
        predicted_error = self.error_estimate + self.process_variance
        kalman_gain = predicted_error / (predicted_error + self.measurement_variance)
        self.estimate = predicted_estimate + kalman_gain * (measurement - predicted_estimate)
        self.error_estimate = (1 - kalman_gain) * predicted_error
        return self.estimate


# ─── Telemetry logger ────────────────────────────────────────────────────────

class TelemetryLogger:
    """Append-only JSONL telemetry logger for ML training data collection.

    Logs one record per calculate_link() tick (~10Hz) with all link metrics,
    scoring sub-components, and selected profile parameters. Includes outcome
    labeling that tracks link quality in the ticks following a profile change.
    """

    def __init__(self, log_dir, rotate_mb=50, outcome_window=10):
        self.log_dir = log_dir
        self.rotate_bytes = rotate_mb * 1024 * 1024
        self.outcome_window = outcome_window
        self._file = None
        self._file_size = 0
        self._file_index = 0

        # Outcome tracking: ring buffer of loss_rate after profile changes
        self._outcome_ticks_remaining = 0
        self._outcome_losses = []
        self._outcome_change_record = None
        self._pending_outcomes = []  # completed outcome labels to flush

        os.makedirs(log_dir, exist_ok=True)
        self._open_file()

    def _log_path(self):
        return os.path.join(self.log_dir, f"telemetry_{self._file_index}.jsonl")

    def _open_file(self):
        path = self._log_path()
        if os.path.exists(path):
            self._file_size = os.path.getsize(path)
        else:
            self._file_size = 0
        self._file = open(path, 'a')

    def _rotate_if_needed(self):
        if self._file_size >= self.rotate_bytes:
            self._file.close()
            self._file_index += 1
            self._open_file()

    def _write_record(self, record):
        line = json.dumps(record, separators=(',', ':')) + '\n'
        self._file.write(line)
        self._file.flush()
        self._file_size += len(line.encode('utf-8'))
        self._rotate_if_needed()

    def log(self, timestamp_ms, best_rssi, best_snr, min_rssi, num_antennas,
            all_packets, lost_packets, fec_rec_packets, fec_k, fec_n,
            loss_rate, fec_pressure, rf_score, loss_score, fec_score,
            diversity_score, combined_score, ema_fast, ema_slow, snr_ema,
            profile, profile_changed, adapter_id='default'):
        record = {
            'ts': timestamp_ms,
            'rssi': best_rssi,
            'snr': best_snr,
            'rssi_min': min_rssi,
            'ant': num_antennas,
            'pkt_all': all_packets,
            'pkt_lost': lost_packets,
            'pkt_fec': fec_rec_packets,
            'fec_k': fec_k,
            'fec_n': fec_n,
            'loss_rate': round(loss_rate, 6),
            'fec_pressure': round(fec_pressure, 4),
            'rf_score': round(rf_score, 4),
            'loss_score': round(loss_score, 4),
            'fec_score': round(fec_score, 4),
            'div_score': round(diversity_score, 4),
            'score': round(combined_score, 1),
            'ema_fast': round(ema_fast, 1),
            'ema_slow': round(ema_slow, 1),
            'snr_ema': round(snr_ema, 2),
            'changed': profile_changed,
            'adapter': adapter_id,
        }
        if profile is not None:
            record['mcs'] = profile['mcs']
            record['gi'] = profile['gi']
            record['sel_fec_k'] = profile['fec_k']
            record['sel_fec_n'] = profile['fec_n']
            record['bitrate'] = profile['bitrate']
            record['power'] = profile['power']

        self._write_record(record)

        # Outcome tracking
        if profile_changed:
            # Finalize any pending outcome window
            self._finalize_outcome()
            self._outcome_ticks_remaining = self.outcome_window
            self._outcome_losses = []
            self._outcome_change_record = {'ts': timestamp_ms}

        if self._outcome_ticks_remaining > 0:
            self._outcome_losses.append(loss_rate)
            self._outcome_ticks_remaining -= 1
            if self._outcome_ticks_remaining == 0:
                self._finalize_outcome()

    def _finalize_outcome(self):
        if not self._outcome_losses or self._outcome_change_record is None:
            return
        avg_loss = sum(self._outcome_losses) / len(self._outcome_losses)
        max_loss = max(self._outcome_losses)
        if max_loss > 0.05:
            label = 'bad'
        elif avg_loss > 0.02:
            label = 'marginal'
        else:
            label = 'good'
        outcome = {
            'type': 'outcome',
            'change_ts': self._outcome_change_record['ts'],
            'avg_loss': round(avg_loss, 6),
            'max_loss': round(max_loss, 6),
            'label': label,
            'ticks': len(self._outcome_losses),
        }
        self._write_record(outcome)
        self._outcome_change_record = None
        self._outcome_losses = []

    def close(self):
        self._finalize_outcome()
        if self._file:
            self._file.close()
            self._file = None


# ─── Profile selector ────────────────────────────────────────────────────────

class ProfileSelector:
    """Multi-factor profile selection with EMA smoothing, hysteresis,
    confidence gating, and hold timers.

    Ported from the drone-side C implementation (profile.c) and enhanced
    with additional scoring factors available on the GS.
    """

    def __init__(self, profiles, config):
        self.profiles = profiles

        # Scoring weights
        self.rf_weight = config.getfloat('scoring', 'rf_weight')
        self.loss_weight = config.getfloat('scoring', 'loss_weight')
        self.fec_weight = config.getfloat('scoring', 'fec_weight')
        self.diversity_weight = config.getfloat('scoring', 'diversity_weight')
        self.max_loss_rate = config.getfloat('scoring', 'max_loss_rate')
        self.max_rssi_spread = config.getfloat('scoring', 'max_rssi_spread')

        # RF normalization ranges
        self.snr_weight = config.getfloat('weights', 'snr_weight')
        self.rssi_weight = config.getfloat('weights', 'rssi_weight')
        self.snr_min = config.getint('ranges', 'SNR_MIN')
        self.snr_max = config.getint('ranges', 'SNR_MAX')
        self.rssi_min = config.getint('ranges', 'RSSI_MIN')
        self.rssi_max = config.getint('ranges', 'RSSI_MAX')

        # Selection tuning
        ps = 'profile selection'
        self.hold_fallback_mode_ms = config.getint(ps, 'hold_fallback_mode_ms')
        self.hold_modes_down_ms = config.getint(ps, 'hold_modes_down_ms')
        self.min_between_changes_ms = config.getint(ps, 'min_between_changes_ms')
        self.hysteresis_percent = config.getfloat(ps, 'hysteresis_percent')
        self.hysteresis_percent_down = config.getfloat(ps, 'hysteresis_percent_down')
        self.ema_fast_alpha = config.getfloat(ps, 'ema_fast_alpha')
        self.ema_slow_alpha = config.getfloat(ps, 'ema_slow_alpha')
        self.predict_multi = config.getfloat(ps, 'predict_multi')
        self.fast_downgrade = config.getboolean(ps, 'fast_downgrade')
        self.upward_confidence_loops = config.getint(ps, 'upward_confidence_loops')
        self.limit_max_score_to = config.getint(ps, 'limit_max_score_to')

        # State
        self.current_profile_idx = -1
        self.previous_profile_idx = -2
        self.current_profile = None
        self.smoothed_value = 1500.0
        self.ema_fast = 0.0
        self.ema_slow = 0.0
        self.ema_initialized = False
        self.last_value_sent = 100
        self.last_change_time_ms = 0
        self.up_confidence_count = 0
        self.up_target_profile = -1

        # Dynamic mode
        self.dynamic_mode = config.getboolean(ps, 'dynamic_mode', fallback=False)
        if self.dynamic_mode:
            d = 'dynamic'
            self.snr_safety_margin = config.getfloat(d, 'snr_safety_margin')
            self.snr_ema_alpha = config.getfloat(d, 'snr_ema_alpha')
            self.loss_margin_weight = config.getfloat(d, 'loss_margin_weight')
            self.fec_margin_weight = config.getfloat(d, 'fec_margin_weight')
            self.dyn_max_mcs = config.getint(d, 'max_mcs')
            self.short_gi_snr_margin = config.getfloat(d, 'short_gi_snr_margin')
            self.loss_threshold_for_fec_downgrade = config.getfloat(d, 'loss_threshold_for_fec_downgrade')
            self.utilization_factor = config.getfloat(d, 'utilization_factor')
            self.dyn_max_bitrate = config.getint(d, 'max_bitrate')
            self.dyn_min_bitrate = config.getint(d, 'min_bitrate')
            self.dyn_max_power = config.getint(d, 'max_power')
            self.dyn_min_power = config.getint(d, 'min_power')
            self.dyn_bandwidth = config.getint(d, 'bandwidth')
            self.dyn_gop = config.getfloat(d, 'gop')
            self.dyn_qp_delta = config.getint(d, 'qp_delta')
            self.dyn_roi_qp = config.get(d, 'roi_qp')

        # SNR EMA state (used in dynamic mode)
        self.snr_ema = 0.0
        self.snr_ema_initialized = False
        self._current_loss_rate = 0.0
        self._current_fec_pressure = 0.0

        # Sub-score tracking (for telemetry)
        self._last_rf_score = 0.0
        self._last_loss_score = 1.0
        self._last_fec_score = 1.0
        self._last_diversity_score = 1.0

        # Packet delta tracking
        self.prev_all_packets = 0
        self.prev_lost_packets = 0
        self.prev_fec_rec = 0

    def _clamp(self, val, lo, hi):
        return max(lo, min(hi, val))

    def _now_ms(self):
        return int(time.monotonic() * 1000)

    def _lookup_profile(self, score):
        """Find profile matching score range. Returns (index, profile) or (None, None)."""
        for i, p in enumerate(self.profiles):
            if p['range_min'] <= score <= p['range_max']:
                return i, p
        return None, None

    def _compute_power(self, mcs):
        """Scale TX power inversely with MCS level."""
        pw_range = self.dyn_max_power - self.dyn_min_power
        if mcs <= 1:
            return self.dyn_max_power
        elif mcs <= 3:
            return self.dyn_max_power - pw_range // 3
        elif mcs <= 5:
            return self.dyn_min_power + pw_range // 3
        else:
            return self.dyn_min_power

    def _compute_profile(self):
        """Dynamically compute profile parameters from link metrics."""
        snr = self.snr_ema
        loss_rate = self._current_loss_rate
        fec_pressure = self._current_fec_pressure

        # Dynamic safety margin — widens when link is stressed
        margin = (self.snr_safety_margin +
                  loss_rate * self.loss_margin_weight +
                  fec_pressure * self.fec_margin_weight)

        # MCS selection: highest where SNR exceeds threshold + margin
        mcs = 0
        for m in range(min(7, self.dyn_max_mcs), -1, -1):
            if snr >= MCS_SNR_THRESHOLDS[m] + margin:
                mcs = m
                break

        # Guard interval: short only when SNR margin is comfortable
        snr_above = snr - MCS_SNR_THRESHOLDS[mcs]
        use_short_gi = (snr_above >= self.short_gi_snr_margin and
                        loss_rate < 0.02 and fec_pressure < 0.3)

        # FEC: base from MCS table, increase redundancy under loss
        fec_k, fec_n = FEC_TABLE[mcs]
        if loss_rate > self.loss_threshold_for_fec_downgrade:
            fec_k = max(2, fec_k - 2)

        # Bitrate: derived from PHY rate, FEC efficiency, utilization
        phy_rates = PHY_RATES_40MHZ if self.dyn_bandwidth == 40 else PHY_RATES_20MHZ
        phy_rate = phy_rates[mcs][1 if use_short_gi else 0]
        bitrate = int(phy_rate * 1000 * (fec_k / fec_n) * self.utilization_factor)
        bitrate = max(self.dyn_min_bitrate, min(self.dyn_max_bitrate, bitrate))

        return {
            'gi': 'short' if use_short_gi else 'long',
            'mcs': mcs,
            'fec_k': fec_k,
            'fec_n': fec_n,
            'bitrate': bitrate,
            'gop': self.dyn_gop,
            'power': self._compute_power(mcs),
            'roi_qp': self.dyn_roi_qp,
            'bandwidth': self.dyn_bandwidth,
            'qp_delta': self.dyn_qp_delta,
        }

    def compute_score(self, best_rssi, best_snr, min_rssi,
                      all_packets, lost_packets, fec_rec,
                      fec_k, fec_n, num_antennas):
        """Multi-factor link quality score (1000-2000 range)."""

        # 1. RF quality (normalized 0-1)
        snr_range = self.snr_max - self.snr_min
        rssi_range = self.rssi_max - self.rssi_min
        snr_norm = self._clamp((best_snr - self.snr_min) / snr_range, 0, 1) if snr_range > 0 else 0
        rssi_norm = self._clamp((best_rssi - self.rssi_min) / rssi_range, 0, 1) if rssi_range > 0 else 0
        rf_score = self.snr_weight * snr_norm + self.rssi_weight * rssi_norm

        # 2. Packet loss rate (over interval)
        delta_lost = max(0, lost_packets - self.prev_lost_packets)
        delta_all = max(0, all_packets - self.prev_all_packets)
        loss_rate = delta_lost / max(delta_all, 1)
        loss_score = 1.0 - self._clamp(loss_rate / self.max_loss_rate, 0, 1)

        # 3. FEC pressure
        delta_fec = max(0, fec_rec - self.prev_fec_rec)
        fec_redundancy = (fec_n - fec_k) if (fec_k and fec_n and fec_n > fec_k) else 1
        fec_capacity = fec_redundancy * (delta_all / max(fec_n, 1)) if fec_n else 1
        fec_pressure = delta_fec / max(fec_capacity, 1)
        fec_score = 1.0 - self._clamp(fec_pressure, 0, 1)

        # 4. Antenna diversity penalty
        if num_antennas > 1 and min_rssi > -200:
            rssi_spread = best_rssi - min_rssi
            diversity_score = 1.0 - self._clamp(rssi_spread / self.max_rssi_spread, 0, 1)
        else:
            diversity_score = 1.0  # Single antenna or no data — no penalty

        # 5. Weighted combination
        combined = (self.rf_weight * rf_score +
                    self.loss_weight * loss_score +
                    self.fec_weight * fec_score +
                    self.diversity_weight * diversity_score)

        # Update delta tracking
        self.prev_all_packets = all_packets
        self.prev_lost_packets = lost_packets
        self.prev_fec_rec = fec_rec

        # Track sub-scores and condition metrics
        self._last_rf_score = rf_score
        self._last_loss_score = loss_score
        self._last_fec_score = fec_score
        self._last_diversity_score = diversity_score
        self._current_loss_rate = loss_rate
        self._current_fec_pressure = self._clamp(fec_pressure, 0, 1)

        if self.dynamic_mode:
            if not self.snr_ema_initialized:
                self.snr_ema = best_snr
                self.snr_ema_initialized = True
            else:
                self.snr_ema = (self.snr_ema_alpha * best_snr +
                                (1.0 - self.snr_ema_alpha) * self.snr_ema)

        return 1000 + combined * 1000

    def select(self, raw_score):
        """Run selection algorithm on a raw score. Returns (changed, profile_index, profile) tuple.

        If changed is False, the caller should send a heartbeat instead.
        """
        # Cap score
        if self.limit_max_score_to < 2000 and raw_score > self.limit_max_score_to:
            raw_score = float(self.limit_max_score_to)

        # Dual EMA smoothing
        if not self.ema_initialized:
            self.ema_fast = raw_score
            self.ema_slow = raw_score
            self.smoothed_value = raw_score
            self.ema_initialized = True
        else:
            self.ema_fast = self.ema_fast_alpha * raw_score + (1.0 - self.ema_fast_alpha) * self.ema_fast
            self.ema_slow = self.ema_slow_alpha * raw_score + (1.0 - self.ema_slow_alpha) * self.ema_slow

        # Legacy single-EMA (asymmetric up/down)
        sf = 0.5 if raw_score >= self.last_value_sent else 0.8
        self.smoothed_value = sf * raw_score + (1 - sf) * self.smoothed_value

        # Predictive score
        effective_score = self.smoothed_value
        if self.ema_fast < self.ema_slow and self.predict_multi > 0:
            gap = self.ema_slow - self.ema_fast
            predicted = self.ema_fast - gap * self.predict_multi
            if predicted < effective_score:
                effective_score = predicted

        # Rate limit
        now_ms = self._now_ms()
        if (now_ms - self.last_change_time_ms) < self.min_between_changes_ms:
            return False, self.current_profile_idx, self.current_profile

        # Clamp to valid range
        combined_value = int(math.floor(effective_score))
        combined_value = max(1000, min(2000, combined_value))

        # Hysteresis check
        if self.last_value_sent != 0:
            percent_change = abs((combined_value - self.last_value_sent) / self.last_value_sent) * 100
        else:
            percent_change = 100

        is_downgrade = combined_value < self.last_value_sent
        threshold = self.hysteresis_percent_down if is_downgrade else self.hysteresis_percent

        if percent_change < threshold:
            # Not enough change — but still feed confidence counter for upgrades
            if not is_downgrade and combined_value != self.last_value_sent:
                self._try_confidence_feed(combined_value)
            return False, self.current_profile_idx, self.current_profile

        # Profile determination
        if self.dynamic_mode:
            new_profile = self._compute_profile()
            new_idx = new_profile['mcs']
        else:
            new_idx, new_profile = self._lookup_profile(combined_value)
            if new_idx is None:
                return False, self.current_profile_idx, self.current_profile

        if new_idx == self.current_profile_idx:
            self.up_confidence_count = 0
            self.up_target_profile = -1
            # In dynamic mode, update profile params even if MCS unchanged
            if self.dynamic_mode:
                self.current_profile = new_profile
            return False, self.current_profile_idx, self.current_profile

        # Direction
        is_profile_downgrade = new_idx < self.current_profile_idx

        # Timing and confidence gating
        elapsed_ms = now_ms - self.last_change_time_ms

        if is_profile_downgrade and self.fast_downgrade:
            # Fast downgrade — apply immediately
            self.up_confidence_count = 0
            self.up_target_profile = -1
        elif self.current_profile_idx == 0:
            # Exiting fallback — enforce fallback hold
            if elapsed_ms <= self.hold_fallback_mode_ms:
                return False, self.current_profile_idx, self.current_profile
        elif not is_profile_downgrade:
            # Upgrade — confidence gating
            if new_idx != self.up_target_profile:
                self.up_target_profile = new_idx
                self.up_confidence_count = 1
                return False, self.current_profile_idx, self.current_profile
            self.up_confidence_count += 1
            if self.up_confidence_count < self.upward_confidence_loops:
                return False, self.current_profile_idx, self.current_profile
            # Also enforce hold timer for upgrades
            if elapsed_ms <= self.hold_modes_down_ms:
                return False, self.current_profile_idx, self.current_profile

        # Apply the change
        self.previous_profile_idx = self.current_profile_idx
        self.current_profile_idx = new_idx
        self.current_profile = new_profile
        self.last_value_sent = combined_value
        self.last_change_time_ms = now_ms
        self.up_confidence_count = 0
        self.up_target_profile = -1

        return True, new_idx, new_profile

    def _try_confidence_feed(self, combined_value):
        """Feed the confidence counter even when hysteresis isn't met."""
        if self.dynamic_mode:
            new_profile = self._compute_profile()
            new_idx = new_profile['mcs']
        else:
            new_idx, _ = self._lookup_profile(combined_value)
        if new_idx is not None and new_idx != self.current_profile_idx and new_idx > self.current_profile_idx:
            if new_idx != self.up_target_profile:
                self.up_target_profile = new_idx
                self.up_confidence_count = 1
            else:
                self.up_confidence_count += 1


# ─── Message generation ──────────────────────────────────────────────────────

def send_udp(message):
    message_bytes = message.encode('utf-8')
    message_size = struct.pack('!I', len(message_bytes))
    full_message = message_size + message_bytes

    try:
        udp_socket.sendto(full_message, (udp_ip, udp_port))
        if verbose_mode:
            print(f"\nUDP Message Sent: {message} (size: {len(message_bytes)} bytes)\n")
    except Exception as e:
        if verbose_mode:
            print(f"Error sending UDP data: {e}")


def generate_profile_message(profile_idx, profile):
    """Generate a P: profile change message."""
    global keyframe_request_code, keyframe_request_remaining
    timestamp = int(time.time())

    parts = [
        "P",
        str(profile_idx),
        profile['gi'],
        str(profile['mcs']),
        str(profile['fec_k']),
        str(profile['fec_n']),
        str(profile['bitrate']),
        str(profile['gop']),
        str(profile['power']),
        profile['roi_qp'],
        str(profile['bandwidth']),
        str(profile['qp_delta']),
        str(timestamp),
    ]

    if keyframe_request_code is not None and keyframe_request_remaining > 0:
        parts.append(keyframe_request_code)
        keyframe_request_remaining -= 1
        if keyframe_request_remaining == 0:
            keyframe_request_code = None

    send_udp(":".join(parts))



# ─── FEC adjustment helper ───────────────────────────────────────────────────

def adjust_fec_recovered(fec_rec, fec_k_val, fec_n_val):
    if fec_k_val is None or fec_n_val is None or fec_n_val == 0:
        return fec_rec
    redundancy = fec_n_val - fec_k_val
    weight = 6.0 / (1 + redundancy)
    return fec_rec * weight


# ─── Main link calculation ───────────────────────────────────────────────────

def calculate_link():
    global best_rssi, best_snr, min_rssi, lost_packets, fec_rec_packets
    global final_score, penalty
    global keyframe_request_code, keyframe_request_remaining

    # Keyframe request on packet loss
    if lost_packets > 0 and allow_idr:
        keyframe_request_code = ''.join(random.choices(string.ascii_lowercase, k=4))
        keyframe_request_remaining = idr_max_messages
        if verbose_mode:
            print(f"Generated new keyframe request code: {keyframe_request_code}")

    # Kalman-filtered noise estimation for penalty
    if all_packets == 0 or num_antennas == 0:
        filtered_noise = 0
    else:
        adjusted_fec_rec = adjust_fec_recovered(fec_rec_packets, fec_k, fec_n)
        error_ratio = (5 * lost_packets + adjusted_fec_rec) / (all_packets / num_antennas)
        filtered_noise = kalman.update(error_ratio)

    # Compute multi-factor score
    raw_score = profile_selector.compute_score(
        best_rssi, best_snr, min_rssi,
        all_packets, lost_packets, fec_rec_packets,
        fec_k, fec_n, num_antennas
    )

    # Optional noise penalty
    if allow_penalty and filtered_noise >= min_noise:
        deduction_ratio = min(((filtered_noise - min_noise) / (max_noise - min_noise)) ** deduction_exponent, 1.0)
        raw_score = 1000 + (raw_score - 1000) * (1 - deduction_ratio)

    final_score = raw_score

    if verbose_mode:
        msg = (f"Score: {final_score:.0f} | RSSI: {best_rssi} | SNR: {best_snr} | "
               f"Lost: {lost_packets} | FEC rec: {fec_rec_packets}")
        if profile_selector.dynamic_mode:
            msg += (f" | SNR_EMA: {profile_selector.snr_ema:.1f} | "
                    f"loss: {profile_selector._current_loss_rate:.3f} | "
                    f"fec_p: {profile_selector._current_fec_pressure:.2f}")
        print(msg)

    # Run profile selection
    changed, idx, profile = profile_selector.select(final_score)

    if changed and verbose_mode and profile is not None:
        print(f">>> Profile change: idx={idx} mcs={profile['mcs']} "
              f"bitrate={profile['bitrate']} fec={profile['fec_k']}/{profile['fec_n']} "
              f"gi={profile['gi']} power={profile['power']}")

    # Telemetry logging
    if telemetry_logger is not None:
        telemetry_logger.log(
            timestamp_ms=int(time.monotonic() * 1000),
            best_rssi=best_rssi,
            best_snr=best_snr,
            min_rssi=min_rssi,
            num_antennas=num_antennas,
            all_packets=all_packets,
            lost_packets=lost_packets,
            fec_rec_packets=fec_rec_packets,
            fec_k=fec_k,
            fec_n=fec_n,
            loss_rate=profile_selector._current_loss_rate,
            fec_pressure=profile_selector._current_fec_pressure,
            rf_score=profile_selector._last_rf_score,
            loss_score=profile_selector._last_loss_score,
            fec_score=profile_selector._last_fec_score,
            diversity_score=profile_selector._last_diversity_score,
            combined_score=final_score,
            ema_fast=profile_selector.ema_fast,
            ema_slow=profile_selector.ema_slow,
            snr_ema=profile_selector.snr_ema,
            profile=profile,
            profile_changed=changed,
            adapter_id=telemetry_adapter_id,
        )

    # Always send current profile — UDP is lossy, so repeating ensures
    # the drone converges even if messages are dropped. The drone's
    # delta detection prevents redundant command execution.
    cur_idx = profile_selector.current_profile_idx
    cur_prof = profile_selector.current_profile
    if cur_prof is not None:
        generate_profile_message(cur_idx, cur_prof)



# ─── wfb-ng stats handling ───────────────────────────────────────────────────

def connect_to_server(host, port):
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.connect((host, port))
    print(f"\nReceiving wfb-ng stats from {host}:{port}")
    return sock


def handle_video_rx_stats(data):
    global best_rssi, best_snr, min_rssi, all_packets, fec_rec_packets, lost_packets
    global fec_k, fec_n, receiving_video, num_antennas
    global waiting_for_video_printed, video_rx_initial_message_printed
    global keyframe_request_code, keyframe_request_remaining

    packets = data.get("packets", {})
    all_packets = packets.get("all", [0])[0]
    receiving_video = (all_packets != 0)

    fec_rec_packets = packets.get("fec_rec", [0])[0]
    lost_packets = packets.get("lost", [0])[0]

    session = data.get("session") or {}
    fec_k = session.get("fec_k")
    fec_n = session.get("fec_n")

    rx_ant_stats = data.get("rx_ant_stats", [])
    num_antennas = len(rx_ant_stats)

    best_rssi = -101
    best_snr = 0
    min_rssi = 0
    for ant in rx_ant_stats:
        rssi = ant.get("rssi_avg")
        snr = ant.get("snr_avg")
        if rssi is not None:
            if rssi > best_rssi:
                best_rssi = rssi
            if min_rssi == 0 or rssi < min_rssi:
                min_rssi = rssi
        if snr is not None and snr > best_snr:
            best_snr = snr

    if receiving_video:
        if not video_rx_initial_message_printed:
            print("\nReceiving video_rx stats\nWorking...")
            video_rx_initial_message_printed = True

            keyframe_request_code = ''.join(random.choices(string.ascii_lowercase, k=4))
            keyframe_request_remaining = idr_max_messages
            if verbose_mode:
                print(f"Generated new keyframe request code on video start: {keyframe_request_code}")

        waiting_for_video_printed = False
        calculate_link()
    else:
        video_rx_initial_message_printed = False
        if not waiting_for_video_printed:
            print("\nWaiting for video_rx stats...")
            waiting_for_video_printed = True


def process_data_line(line):
    try:
        return json.loads(line)
    except json.JSONDecodeError:
        return None


def listen_for_data(sock):
    global waiting_for_video_printed
    waiting_for_video_printed = False
    try:
        with sock.makefile() as f:
            for line in f:
                if not line:
                    break
                data = process_data_line(line)
                if data is None:
                    continue
                if data.get("type") == "rx" and data.get("id") == "video rx":
                    handle_video_rx_stats(data)
                else:
                    global receiving_video
                    receiving_video = False
    except Exception as e:
        if verbose_mode:
            print(f"Error processing data: {e}")


def connect_to_wfb_stats():
    while True:
        sock = None
        try:
            sock = connect_to_server(HOST, PORT)
            listen_for_data(sock)
        except (socket.error, ConnectionRefusedError) as e:
            print(f"\n! Check VRX adapter(s)...\nNo connection to wfb-ng stats\n{e}\nRetrying in 3 seconds...")
        finally:
            if sock:
                sock.close()
            time.sleep(3)


