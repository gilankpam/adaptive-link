    udp_port = config.getint('outgoing', 'udp_port')

    # JSON data settings
    host = config.get('wfb-ng', 'host')
    port = config.getint('wfb-ng', 'port')

    # Keyframe settings
    allow_idr = config.getboolean('keyframe', 'allow_idr')
    idr_max_messages = config.getint('keyframe', 'idr_max_messages')

    udp_socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    udp_socket.bind(("", 0))
    udp_socket.setblocking(False)

    handshake = HandshakeClient(
        udp_socket, udp_ip, udp_port,
        resync_interval_s=config.getint('handshake', 'resync_interval_s', fallback=30),
        default_fps=config.getint('dynamic', 'video_fps_default', fallback=90),
    )

    # Initialize profile selector
    profile_selector = ProfileSelector(config, handshake)

    # Initialize telemetry logger
    telemetry_logger = None
