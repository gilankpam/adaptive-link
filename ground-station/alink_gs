    verbose_mode = args.verbose

    config = load_configuration(args.config)

    # Outgoing settings (UDP)
    udp_ip = config.get('outgoing', 'udp_ip')
    udp_port = config.getint('outgoing', 'udp_port')

    # JSON data settings
    HOST = config.get('json', 'HOST')
    PORT = config.getint('json', 'PORT')

    # Keyframe settings
    allow_idr = config.getboolean('keyframe', 'allow_idr')
    idr_max_messages = config.getint('keyframe', 'idr_max_messages')

    # Dynamic refinement
    allow_penalty = config.getboolean('dynamic refinement', 'allow_penalty')

    # Noise and penalty parameters
    min_noise = config.getfloat('noise', 'min_noise')
    max_noise = config.getfloat('noise', 'max_noise')
    deduction_exponent = config.getfloat('noise', 'deduction_exponent')

    # Load profiles (optional in dynamic mode)
    dynamic_mode = config.getboolean('profile selection', 'dynamic_mode', fallback=False)
    profiles = []
    if not dynamic_mode:
        txprofiles_file = config.get('profile selection', 'txprofiles_file')
        profiles = load_profiles(txprofiles_file)
        if not profiles:
            print(f"Warning: No profiles loaded from {txprofiles_file}")
    else:
        print("Dynamic profile calculation enabled — txprofiles.conf not required")

    # Initialize profile selector
    profile_selector = ProfileSelector(profiles, config)

    # Initialize Kalman filter
    kalman = KalmanFilter(
        estimate=config.getfloat('error estimation', 'kalman_estimate'),
        error_estimate=config.getfloat('error estimation', 'kalman_error_estimate'),
        process_variance=config.getfloat('error estimation', 'process_variance'),
        measurement_variance=config.getfloat('error estimation', 'measurement_variance'),
    )

    # Initialize telemetry logger
    telemetry_logger = None
    telemetry_adapter_id = config.get('telemetry', 'adapter_id', fallback='default')
    if config.getboolean('telemetry', 'log_enabled', fallback=False):
        log_dir = config.get('telemetry', 'log_dir', fallback='/var/log/alink')
        rotate_mb = config.getint('telemetry', 'log_rotate_mb', fallback=50)
        outcome_window = config.getint('telemetry', 'outcome_window_ticks', fallback=10)
        telemetry_logger = TelemetryLogger(log_dir, rotate_mb, outcome_window)
        print(f"Telemetry logging enabled: {log_dir}")

    # Global state variables
    best_rssi = -101
    best_snr = 0
    min_rssi = 0
    all_packets = 0
    fec_rec_packets = 0
    lost_packets = 0
    fec_k = None
    fec_n = None
    receiving_video = False
    num_antennas = 0
    penalty = 0
    final_score = 1000
    waiting_for_video_printed = False
    video_rx_initial_message_printed = False

    # Keyframe request globals
    keyframe_request_code = None
    keyframe_request_remaining = 0

    udp_socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    connect_to_wfb_stats()
