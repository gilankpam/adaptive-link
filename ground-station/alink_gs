class HandshakeClient:
    """Handshake client for obtaining drone FPS and resolution.

    Two-stage timer:
      - On the happy path, one H: probe per long_resync_ms (~30s).
      - On reply loss, retry every fast_retry_ms (~500ms) up to
        max_fast_retries times before giving up and waiting for the next
        long resync.

    Replies are matched against the t1 of the most recent in-flight hello;
    stale or duplicate replies (e.g. drained from the kernel buffer after a
    stall) are dropped without touching FPS/resolution state. The match is a
    freshness gate, not authentication — the wfb-ng tunnel is trusted.
    """
    def __init__(self, udp_socket, drone_ip, drone_port, default_fps=90,
                 long_resync_ms=30000, fast_retry_ms=500, max_fast_retries=3,
                 rtt_ema_alpha=0.2):
        self.sock = udp_socket
        self.drone_ip = drone_ip
        self.drone_port = drone_port
        self._default_fps = default_fps
        self.drone_fps = None
        self.drone_xres = None
        self.drone_yres = None

        self._long_resync_ms = long_resync_ms
        self._fast_retry_ms = fast_retry_ms
        self._max_fast_retries = max_fast_retries

        # Two-stage timer state
        self._pending_t1 = None         # t1 of in-flight hello, or None
        self._pending_sent_at_ms = 0    # when the in-flight hello was sent
        self._fast_retry_count = 0      # retries used in current burst
        self._next_hello_due_ms = 0     # next hello scheduled for (when idle)

        # Visibility counter — replies that didn't match a pending hello.
        self.unmatched_replies = 0

        # Session tracking — detects drone daemon restarts.
        self.drone_session_id = None
        self.session_changed = False

        # RTT measurement (clock-offset-cancelling).
        # rtt = (gs_recv_ms - t1) - (t3 - t2). Both subtractions stay on a
        # single clock, so the unbounded GS↔drone clock offset never enters.
        self.last_rtt_ms = None
        self.avg_rtt_ms = None
        self._rtt_ema_alpha = rtt_ema_alpha
        self.rtt_invalid_count = 0  # negative/oversized RTT (clock anomaly)

    def force_resync(self):
        """Reset the timer so the next tick() sends a hello immediately.

        Used by callers (e.g. on video-stream return) to short-circuit the
        long resync interval and re-handshake right away.
        """
        self._pending_t1 = None
        self._fast_retry_count = 0
        self._next_hello_due_ms = 0

    def tick(self, now_ms):
        """Call once per main-loop iteration. Drives both stages of the timer."""
        if self._pending_t1 is not None:
            # Awaiting a reply — fire fast retry if window expired.
            if now_ms - self._pending_sent_at_ms >= self._fast_retry_ms:
                if self._fast_retry_count < self._max_fast_retries:
                    self._fast_retry_count += 1
                    self._send_hello(now_ms)
                else:
                    # Burst exhausted; back off until the next long resync.
                    if verbose_mode:
                        print(f"[HANDSHAKE] No reply after {self._max_fast_retries} retries, backing off")
                    self._pending_t1 = None
                    self._fast_retry_count = 0
                    self._next_hello_due_ms = now_ms + self._long_resync_ms
            return

        if now_ms >= self._next_hello_due_ms:
            self._fast_retry_count = 0
            self._send_hello(now_ms)

    def _send_hello(self, now_ms):
        """Send an H: hello message to the drone and arm the pending state."""
        payload = f"H:{now_ms}".encode("ascii")
        frame = struct.pack("!I", len(payload)) + payload
        try:
            self.sock.sendto(frame, (self.drone_ip, self.drone_port))
            self._pending_t1 = now_ms
            self._pending_sent_at_ms = now_ms
            if verbose_mode:
                print(f"[HANDSHAKE] Sent H:{now_ms} to {self.drone_ip}:{self.drone_port}")
        except OSError as e:
            if verbose_mode:
                print(f"[HANDSHAKE] Failed to send hello: {e}")

    def handle_reply(self, payload_str, gs_recv_ms=None):
        """Feed an 'I:' payload. Updates FPS/resolution iff t1 matches the
        most recent in-flight hello; otherwise drops the reply silently and
        bumps `unmatched_replies` for visibility.

        If gs_recv_ms is provided, also computes the clock-offset-cancelling
        RTT: (gs_recv_ms - t1) - (t3 - t2). Both terms subtract values on a
        single clock, so the (unbounded) GS↔drone clock offset never appears
        in the result.
        """
        if not payload_str.startswith("I:"):
            if verbose_mode:
                print(f"[HANDSHAKE] Invalid reply (not I:): {payload_str[:20]}")
            return False
        parts = payload_str[2:].split(":")
        if len(parts) < 6:
            if verbose_mode:
                print(f"[HANDSHAKE] Invalid reply (too few fields): {payload_str}")
            return False
        try:
            # t1, t2, t3, fps, xres, yres
            t1 = int(parts[0])
            t2 = int(parts[1])
            t3 = int(parts[2])
            fps = int(parts[3])
            xres = int(parts[4])
            yres = int(parts[5])
        except ValueError:
            if verbose_mode:
                print(f"[HANDSHAKE] Invalid reply (parse error): {payload_str}")
            return False

        # Freshness gate: only accept the reply for the hello we're waiting on.
        if self._pending_t1 is None or t1 != self._pending_t1:
            self.unmatched_replies += 1
            if verbose_mode:
                print(f"[HANDSHAKE] Unmatched reply t1={t1} pending={self._pending_t1}")
            return False

        # Match — clear pending and schedule next hello at the long interval,
        # measured from when we sent (not from now), to keep cadence stable.
        self._next_hello_due_ms = self._pending_sent_at_ms + self._long_resync_ms
        self._pending_t1 = None
        self._fast_retry_count = 0

        self.drone_fps = fps
        self.drone_xres = xres
        self.drone_yres = yres

        # Optional session_id (field 7) — detects drone daemon restarts.
        session_id = None
        if len(parts) >= 7:
            try:
                session_id = int(parts[6])
            except ValueError:
                pass
        if session_id is not None:
            if self.drone_session_id is not None and session_id != self.drone_session_id:
                self.session_changed = True
                if verbose_mode:
                    print(f"[HANDSHAKE] Drone session changed: "
                          f"{self.drone_session_id} -> {session_id}")
            self.drone_session_id = session_id

        if gs_recv_ms is not None:
            self._update_rtt(t1, t2, t3, gs_recv_ms)

        if verbose_mode:
            print(f"[HANDSHAKE] Got drone info: fps={fps} res={xres}x{yres}"
                  + (f" rtt={self.last_rtt_ms}ms" if self.last_rtt_ms is not None else ""))
        return True

    def _update_rtt(self, t1, t2, t3, gs_recv_ms):
        """Compute (gs_recv - t1) - (t3 - t2) and update last/avg RTT.

        Drops obviously broken samples (negative RTT, drone-side processing
        time longer than the round trip) — those indicate a clock anomaly
        or a bug in the stamping path, not a real measurement.
        """
        rtt = (gs_recv_ms - t1) - (t3 - t2)
        if rtt < 0 or t3 < t2:
            self.rtt_invalid_count += 1
            if verbose_mode:
                print(f"[HANDSHAKE] Bogus RTT sample: rtt={rtt} "
                      f"gs_recv-t1={gs_recv_ms - t1} t3-t2={t3 - t2}")
            return
        self.last_rtt_ms = rtt
        if self.avg_rtt_ms is None:
            self.avg_rtt_ms = float(rtt)
        else:
            a = self._rtt_ema_alpha
            self.avg_rtt_ms = a * rtt + (1.0 - a) * self.avg_rtt_ms

    def get_fps(self):
        return self.drone_fps if self.drone_fps is not None else self._default_fps

    def get_rtt_ms(self):
        """Latest measured RTT in milliseconds, or None if never measured."""
        return self.last_rtt_ms

    def get_avg_rtt_ms(self):
        """EMA-smoothed RTT in milliseconds, or None if never measured."""
        return self.avg_rtt_ms

    def pop_session_changed(self):
        """Return True (once) if the drone restarted since the last check."""
        if self.session_changed:
            self.session_changed = False
            return True
        return False


class ProfileSelector:
    """Two-channel gate profile selector.

    Channel A: SNR margin (slow/symmetric) drives normal upgrades and
               graceful downgrades with confidence gating and trend prediction.
    Channel B: Emergency triggers (fast/asymmetric) force immediate one-step
               downgrade on excessive loss rate or FEC pressure.

    The actual profile parameters (MCS/FEC/bitrate/GI/power) are computed by
    _compute_profile() from physical link metrics.
    """

    def __init__(self, config, handshake):
        self.handshake = handshake
        # Selection tuning
        ps = 'profile selection'
        self.hold_fallback_mode_ms = config.getint(ps, 'hold_fallback_mode_ms')
        self.hold_modes_down_ms = config.getint(ps, 'hold_modes_down_ms')
        self.min_between_changes_ms = config.getint(ps, 'min_between_changes_ms')
        self.fast_downgrade = config.getboolean(ps, 'fast_downgrade')
        self.upward_confidence_loops = config.getint(ps, 'upward_confidence_loops')

        # Two-channel gate tuning
        g = 'gate'
        self.hysteresis_up_db = config.getfloat(g, 'hysteresis_up_db')
        self.hysteresis_down_db = config.getfloat(g, 'hysteresis_down_db')
        self.snr_slope_alpha = config.getfloat(g, 'snr_slope_alpha')
        self.snr_predict_horizon_ticks = config.getfloat(g, 'snr_predict_horizon_ticks')
        self.emergency_loss_rate = config.getfloat(g, 'emergency_loss_rate')
        self.emergency_fec_pressure = config.getfloat(g, 'emergency_fec_pressure')

        # State
        self.current_profile_idx = -1
        self.previous_profile_idx = -2
        self.current_profile = None
        # last_change_time_ms gates min_between_changes_ms (any profile update).
        # last_mcs_change_time_ms gates hold_modes_down_ms / hold_fallback_mode_ms
        # (MCS transitions only — param-only updates don't reset it).
        self.last_change_time_ms = 0
        self.last_mcs_change_time_ms = 0
        self.up_confidence_count = 0
        self.up_target_profile = -1

        # Dynamic parameters
        d = 'dynamic'
        self.snr_safety_margin = config.getfloat(d, 'snr_safety_margin')
        self.snr_ema_alpha = config.getfloat(d, 'snr_ema_alpha')
        self.loss_margin_weight = config.getfloat(d, 'loss_margin_weight')
        self.fec_margin_weight = config.getfloat(d, 'fec_margin_weight')
        self.dyn_max_mcs = config.getint(d, 'max_mcs')
        self.short_gi_snr_margin = config.getfloat(d, 'short_gi_snr_margin')
        self.loss_threshold_for_fec_downgrade = config.getfloat(d, 'loss_threshold_for_fec_downgrade')
        self.fec_redundancy_ratio = config.getfloat(d, 'fec_redundancy_ratio')
        self.max_fec_redundancy = config.getfloat(d, 'max_fec_redundancy', fallback=0.5)
        self.max_fec_n = config.getint(d, 'max_fec_n', fallback=50)
        self.utilization_factor = config.getfloat(d, 'utilization_factor')
        self.dyn_max_bitrate = config.getint(d, 'max_bitrate')
        self.dyn_min_bitrate = config.getint(d, 'min_bitrate')
        self.dyn_max_power = config.getint(d, 'max_power')
        self.dyn_min_power = config.getint(d, 'min_power')
        self.dyn_bandwidth = config.getint(d, 'bandwidth')
        self.dyn_gop = config.getfloat(d, 'gop')
        self.max_mcs_step_up = config.getint(d, 'max_mcs_step_up', fallback=1)

        # Link state (updated by evaluate_link, consumed by _compute_profile and select)
        self.snr_ema = 0.0
        self.snr_ema_initialized = False
        self._snr_slope = 0.0  # EMA of Δsnr_ema per tick
        self._current_loss_rate = 0.0
        self._current_fec_pressure = 0.0

    def _clamp(self, val, lo, hi):
        return max(lo, min(hi, val))

    def _now_ms(self):
        return int(time.monotonic() * 1000)

    def _compute_power(self, mcs):
        """Scale TX power inversely with MCS level (linear)."""
        max_mcs = min(7, self.dyn_max_mcs)
        if max_mcs <= 0:
            return self.dyn_max_power
        t = self._clamp(mcs / max_mcs, 0.0, 1.0)
        return round(self.dyn_max_power - t * (self.dyn_max_power - self.dyn_min_power))

    def _compute_fec_from_bitrate(self, bitrate_bps, redundancy_ratio=None):
        """Compute FEC K,N from bitrate using frame-proportional block sizing.

        Sizes K to match the expected number of packets per video frame.
        This is a block-sizing heuristic — wfb-ng forms FEC blocks purely
        sequentially, so K does not create actual alignment with video
        frame boundaries.  Larger K gives better burst-loss tolerance at
        the cost of higher recovery latency when FEC is needed.

        Args:
            bitrate_bps: Target video bitrate in bits per second
            redundancy_ratio: FEC redundancy ratio (default: self.fec_redundancy_ratio)

        Returns:
            Tuple of (fec_k, fec_n) integers
        """
        # Use config value if not provided
        if redundancy_ratio is None:
            redundancy_ratio = self.fec_redundancy_ratio

        # Step 1: Packets per frame = bitrate / (fps * 8 * mtu)
        video_fps = self.handshake.get_fps()
        packets_per_frame = bitrate_bps / (video_fps * 8 * MTU_PAYLOAD_BYTES)

        # Step 2: K = ceil(packets_per_frame) — proportional block sizing
        fec_k = max(2, math.ceil(packets_per_frame))

        # Step 3: Apply configurable redundancy ratio
        # N = K / (1 - redundancy_ratio)
        # For 25% redundancy (0.25): N = K / 0.75 = K * 1.333...
        fec_n = math.ceil(fec_k / (1 - redundancy_ratio))

        return fec_k, fec_n

    def _profile_changed(self, old, new):
        """Compare two profile dicts, return True if any parameter differs.

        Compares: gi, mcs, fec_k, fec_n, bitrate, power.
        Excludes gop and bandwidth as they are static config values.
        """
        for key in ('gi', 'mcs', 'fec_k', 'fec_n', 'bitrate', 'power'):
            if old.get(key) != new.get(key):
                return True
        return False

    def _compute_profile(self, mcs_override=None):
        """Dynamically compute profile parameters from link metrics."""
        snr = self.snr_ema
        loss_rate = self._current_loss_rate
        fec_pressure = self._current_fec_pressure

        # Dynamic safety margin — widens when link is stressed
        margin = (self.snr_safety_margin +
                  loss_rate * self.loss_margin_weight +
                  fec_pressure * self.fec_margin_weight)

        # MCS selection: highest where SNR exceeds threshold + margin
        if mcs_override is not None:
            mcs = mcs_override
        else:
            mcs = 0
            for m in range(min(7, self.dyn_max_mcs), -1, -1):
                if snr >= MCS_SNR_THRESHOLDS[m] + margin:
                    mcs = m
                    break

        # Guard interval: short only when SNR margin is comfortable
        snr_above = snr - MCS_SNR_THRESHOLDS[mcs]
        use_short_gi = (snr_above >= self.short_gi_snr_margin and
                        loss_rate < 0.02 and fec_pressure < 0.3)

        # Bitrate & FEC: compute together — FEC block size scales with bitrate
        phy_rates = PHY_RATES_40MHZ if self.dyn_bandwidth == 40 else PHY_RATES_20MHZ
        phy_rate = phy_rates[mcs][1 if use_short_gi else 0]

        # Raw air capacity in bps (PHY rate × utilization factor)
        link_bandwidth_bps = int(1000 * 1000 * phy_rate * self.utilization_factor)

        # Target video bitrate = raw capacity × (1 - redundancy_ratio),
        # capped at max_bitrate so FEC blocks are sized for the actual
        # encoder output, not the theoretical link capacity.
        target_bitrate_bps = int(link_bandwidth_bps * (1 - self.fec_redundancy_ratio))
        target_bitrate_bps = min(target_bitrate_bps, self.dyn_max_bitrate * 1000)

        # FEC block sizing proportional to video frame packet count
        # (wfb-ng blocks are sequential, not aligned to frame boundaries)
        fec_k, fec_n = self._compute_fec_from_bitrate(target_bitrate_bps)

        # Increase redundancy under loss (reduce K, keep N constant)
        if loss_rate > self.loss_threshold_for_fec_downgrade:
            fec_k = max(2, fec_k - 1)

        # Enforce max_fec_redundancy
        # Calculate actual redundancy ratio
        actual_redundancy = (fec_n - fec_k) / fec_n
        if actual_redundancy > self.max_fec_redundancy:
            # Recalculate fec_k to match max_fec_redundancy
            fec_k = math.ceil(fec_n * (1 - self.max_fec_redundancy))
            fec_k = max(2, fec_k)

        # Enforce max_fec_n cap
        # When fec_n exceeds max, clamp it and adjust fec_k proportionally
        if fec_n > self.max_fec_n:
            # Preserve the redundancy ratio when clamping
            original_redundancy_ratio = 1 - (fec_k / fec_n)
            fec_n = self.max_fec_n
            fec_k = math.ceil(fec_n * (1 - original_redundancy_ratio))
            fec_k = max(2, fec_k)

        # Final bitrate accounts for actual FEC overhead (K/N ratio)
        bitrate = int(link_bandwidth_bps * (fec_k / fec_n) / 1000)
        bitrate = max(self.dyn_min_bitrate, min(self.dyn_max_bitrate, bitrate))

        return {
            'gi': 'short' if use_short_gi else 'long',
            'mcs': mcs,
            'fec_k': fec_k,
            'fec_n': fec_n,
            'bitrate': bitrate,
            'gop': self.dyn_gop,
            'power': self._compute_power(mcs),
            'bandwidth': self.dyn_bandwidth,
        }

    def evaluate_link(self, best_snr, all_packets, lost_packets, fec_rec, fec_k, fec_n):
        """Update internal link state from one tick of wfb-ng metrics.

        Maintains: snr_ema, _snr_slope, _current_loss_rate, _current_fec_pressure.
        These are consumed by _compute_profile() and select().

        Note: wfb-ng provides per-interval delta values directly, so we use them
        without calculating deltas from previous values.
        """
        # Packet loss rate (all_packets and lost_packets are already per-interval)
        loss_rate = lost_packets / max(all_packets, 1)

        # FEC pressure (recovered packets vs FEC block capacity)
        # fec_rec is already the per-interval count of FEC-recovered packets
        fec_redundancy = (fec_n - fec_k) if (fec_k and fec_n and fec_n > fec_k) else 1
        fec_capacity = fec_redundancy * (all_packets / max(fec_n, 1)) if fec_n else 1
        fec_pressure = fec_rec / max(fec_capacity, 1)

        self._current_loss_rate = self._clamp(loss_rate, 0, 1)
        self._current_fec_pressure = self._clamp(fec_pressure, 0, 1)

        # SNR EMA + slope tracking for predictive gating
        if not self.snr_ema_initialized:
            self.snr_ema = best_snr
            self._snr_slope = 0.0
            self.snr_ema_initialized = True
        else:
            prev_ema = self.snr_ema
            self.snr_ema = (self.snr_ema_alpha * best_snr +
                            (1.0 - self.snr_ema_alpha) * self.snr_ema)
            delta = self.snr_ema - prev_ema
            self._snr_slope = (self.snr_slope_alpha * delta +
                               (1.0 - self.snr_slope_alpha) * self._snr_slope)

    def _margin(self, mcs):
        """SNR margin (dB) above the threshold required for the given MCS.

        Uses the same stress-widening formula as _compute_profile() so the
        gate and the parameter mapper share a single source of truth.
        """
        if mcs < 0 or mcs >= len(MCS_SNR_THRESHOLDS):
            return 0.0
        stress_margin = (self.snr_safety_margin +
                         self._current_loss_rate * self.loss_margin_weight +
                         self._current_fec_pressure * self.fec_margin_weight)
        return self.snr_ema - MCS_SNR_THRESHOLDS[mcs] - stress_margin

    def _emergency_active(self):
        return (self._current_loss_rate >= self.emergency_loss_rate or
                self._current_fec_pressure >= self.emergency_fec_pressure)

    def select(self):
        """Decide whether to apply a new profile based on current link state.

        Returns (changed, profile_index, profile). If changed is False, the
        caller should send a heartbeat instead of a profile message.
        """
        now_ms = self._now_ms()
        emergency = self._emergency_active()

        # Channel B: emergency downgrades bypass rate limit
        if not emergency and (now_ms - self.last_change_time_ms) < self.min_between_changes_ms:
            return False, self.current_profile_idx, self.current_profile

        # Compute candidate from current link state
        new_profile = self._compute_profile()
        new_idx = new_profile['mcs']

        # Emergency forces at least one MCS step down from the current profile
        if emergency and self.current_profile_idx > 0:
            target = self.current_profile_idx - 1
            if new_idx > target:
                new_idx = target
                new_profile = self._compute_profile(mcs_override=new_idx)

        # Upward MCS step limit (prevents power-coupling oscillation)
        if (self.current_profile_idx >= 0 and
                new_idx > self.current_profile_idx and
                self.max_mcs_step_up > 0):
            capped_mcs = self.current_profile_idx + self.max_mcs_step_up
            if new_idx > capped_mcs:
                new_idx = capped_mcs
                new_profile = self._compute_profile(mcs_override=capped_mcs)

        # Channel A: SNR-margin hysteresis (skipped during emergency)
        if not emergency and self.current_profile_idx >= 0:
            cur = self.current_profile_idx
            if new_idx > cur:
                # Upgrade: require headroom above threshold + predictive check
                tgt_margin = self._margin(new_idx)
                predicted = tgt_margin + self._snr_slope * self.snr_predict_horizon_ticks
                if tgt_margin < self.hysteresis_up_db or predicted < 0:
                    # Not enough headroom — still feed confidence counter so that
                    # when headroom arrives the upgrade can fire quickly.
                    self._try_confidence_feed(new_idx)
                    return False, self.current_profile_idx, self.current_profile
            elif new_idx < cur:
                # Downgrade: current or predicted margin must breach threshold
                cur_margin = self._margin(cur)
                predicted = cur_margin + self._snr_slope * self.snr_predict_horizon_ticks
                if (cur_margin > -self.hysteresis_down_db and
                        predicted > -self.hysteresis_down_db):
                    return False, self.current_profile_idx, self.current_profile

        # Same-MCS path: may still need to push updated FEC/bitrate/GI/power
        if new_idx == self.current_profile_idx:
            self.up_confidence_count = 0
            self.up_target_profile = -1
            params_changed = (self.current_profile is None or
                              self._profile_changed(self.current_profile, new_profile))
            self.current_profile = new_profile
            if params_changed:
                self.last_change_time_ms = now_ms
                return True, self.current_profile_idx, self.current_profile
            return False, self.current_profile_idx, self.current_profile

        # Direction + timing + confidence gating
        is_profile_downgrade = new_idx < self.current_profile_idx
        elapsed_since_mcs_ms = now_ms - self.last_mcs_change_time_ms

        if is_profile_downgrade and (emergency or self.fast_downgrade):
            # Fast downgrade — apply immediately
            self.up_confidence_count = 0
            self.up_target_profile = -1
        elif self.current_profile_idx == 0:
            # Exiting fallback — enforce fallback hold
            if elapsed_since_mcs_ms < self.hold_fallback_mode_ms:
                return False, self.current_profile_idx, self.current_profile
        elif not is_profile_downgrade:
            # Upgrade — confidence gating
            if new_idx != self.up_target_profile:
                self.up_target_profile = new_idx
                self.up_confidence_count = 1
                return False, self.current_profile_idx, self.current_profile
            self.up_confidence_count += 1
            if self.up_confidence_count < self.upward_confidence_loops:
                return False, self.current_profile_idx, self.current_profile
            # Also enforce hold timer for upgrades
            if elapsed_since_mcs_ms < self.hold_modes_down_ms:
                return False, self.current_profile_idx, self.current_profile

        # Apply the change
        self.previous_profile_idx = self.current_profile_idx
        self.current_profile_idx = new_idx
        self.current_profile = new_profile
        self.last_change_time_ms = now_ms
        self.last_mcs_change_time_ms = now_ms
        self.up_confidence_count = 0
        self.up_target_profile = -1

        return True, new_idx, new_profile

    def _try_confidence_feed(self, target_idx):
        """Feed the confidence counter toward an upgrade target even when
        hysteresis hasn't been met yet."""
        # Apply step limit so confidence targets the reachable MCS
        if (self.current_profile_idx >= 0 and
                target_idx > self.current_profile_idx and
                self.max_mcs_step_up > 0):
            target_idx = min(target_idx, self.current_profile_idx + self.max_mcs_step_up)
        if target_idx != self.current_profile_idx and target_idx > self.current_profile_idx:
            if target_idx != self.up_target_profile:
                self.up_target_profile = target_idx
                self.up_confidence_count = 1
            else:
                self.up_confidence_count += 1


# ─── Message generation ──────────────────────────────────────────────────────

def _drain_handshake_replies(sock, handshake):
    """Drain all pending datagrams and feed 'I:' payloads to handshake.

    Stamps gs_recv_ms per-datagram (not once for the whole drain) so the RTT
    calculation in handle_reply is anchored to the actual receive time of
    each reply, not the start of the drain pass.
    """
    while True:
        try:
            data, _addr = sock.recvfrom(1024)
        except BlockingIOError:
            return
        gs_recv_ms = int(time.time() * 1000)
        if len(data) < 4:
            continue
        plen = struct.unpack("!I", data[:4])[0]
        if len(data) < 4 + plen:
            continue
        try:
            payload = data[4:4 + plen].decode("utf-8")
        except UnicodeDecodeError:
            continue
        handshake.handle_reply(payload, gs_recv_ms=gs_recv_ms)

def send_udp(message):
    message_bytes = message.encode('utf-8')
    message_size = struct.pack('!I', len(message_bytes))
    full_message = message_size + message_bytes

    try:
        udp_socket.sendto(full_message, (udp_ip, udp_port))
        if verbose_mode:
            print(f"\nUDP Message Sent: {message} (size: {len(message_bytes)} bytes)\n")
    except Exception as e:
        if verbose_mode:
            print(f"Error sending UDP data: {e}")


def generate_profile_message(profile_idx, profile):
    """Generate a P: profile change message."""
    timestamp = int(time.time() * 1000)

    avg_rtt = profile_selector.handshake.get_avg_rtt_ms()
    rtt_field = str(int(round(avg_rtt))) if avg_rtt is not None else "-1"

    parts = [
        "P",
        str(profile_idx),
        profile['gi'],
        str(profile['mcs']),
        str(profile['fec_k']),
        str(profile['fec_n']),
        str(profile['bitrate']),
        str(profile['gop']),
        str(profile['power']),
        str(profile['bandwidth']),
        str(timestamp),
        rtt_field,
    ]

    send_udp(":".join(parts))


def pump_keyframe_sender():
    """Send pending K keyframe request repeats on a fixed interval.

    Called from the main listen loop on every select() wakeup. Decoupled from
    the wfb-ng stats cadence so the first IDR repeat lands within
    idr_send_interval_ms of the loss event instead of waiting for the next
    stats line. The drone rate-limits HTTP calls to the camera API by wall
    clock, so repeats collapse to a single request without per-code dedup.
    """
    global keyframe_request_remaining, last_keyframe_send_ms
    if keyframe_request_remaining <= 0:
        return
    now_ms = time.monotonic() * 1000
    if now_ms - last_keyframe_send_ms < idr_send_interval_ms:
        return
    send_udp("K")
    last_keyframe_send_ms = now_ms
    keyframe_request_remaining -= 1



# ─── Main link calculation ───────────────────────────────────────────────────

def calculate_link():
    global best_rssi, best_snr, min_rssi, lost_packets, fec_rec_packets
    global keyframe_request_remaining

    # Keyframe request on packet loss
    if lost_packets > 0 and allow_idr:
        keyframe_request_remaining = idr_max_messages
        if verbose_mode:
            print("Queued keyframe request burst")

    # Update link state from this tick's metrics
    profile_selector.evaluate_link(
        best_snr, all_packets, lost_packets, fec_rec_packets, fec_k, fec_n
    )

    # Run profile selection
    changed, idx, profile = profile_selector.select()

    # Compute margins for telemetry/verbose (after select, so they reflect
    # the current profile if it changed this tick)
    cur_mcs = profile_selector.current_profile_idx
    margin_cur = profile_selector._margin(cur_mcs) if cur_mcs >= 0 else 0.0
    margin_tgt = profile_selector._margin(profile['mcs']) if profile is not None else 0.0
    emergency = profile_selector._emergency_active()

    if verbose_mode:
        rtt_ms = profile_selector.handshake.get_avg_rtt_ms()
        rtt_str = f" | rtt:{rtt_ms:.0f}ms" if rtt_ms is not None else ""
        msg = (f"SNR_EMA: {profile_selector.snr_ema:.1f} | "
               f"margin[cur]: {margin_cur:+.1f}dB | "
               f"slope: {profile_selector._snr_slope:+.2f} | "
               f"RSSI: {best_rssi} | "
               f"loss: {profile_selector._current_loss_rate:.3f} | "
               f"fec_p: {profile_selector._current_fec_pressure:.2f}"
               f"{rtt_str}"
               f"{' [EMERGENCY]' if emergency else ''}")
        print(msg)

    if changed and verbose_mode and profile is not None:
        print(f">>> Profile change: idx={idx} mcs={profile['mcs']} "
              f"bitrate={profile['bitrate']} fec={profile['fec_k']}/{profile['fec_n']} "
              f"gi={profile['gi']} power={profile['power']}")

    # Telemetry logging
    if telemetry_logger is not None:
        telemetry_logger.log(
            timestamp_ms=int(time.monotonic() * 1000),
            best_rssi=best_rssi,
            best_snr=best_snr,
            min_rssi=min_rssi,
            num_antennas=num_antennas,
            all_packets=all_packets,
            lost_packets=lost_packets,
            fec_rec_packets=fec_rec_packets,
            fec_k=fec_k,
            fec_n=fec_n,
            loss_rate=profile_selector._current_loss_rate,
            fec_pressure=profile_selector._current_fec_pressure,
            snr_ema=profile_selector.snr_ema,
            snr_slope=profile_selector._snr_slope,
            margin_current=margin_cur,
            margin_target=margin_tgt,
            emergency=emergency,
            profile=profile,
            profile_changed=changed,
            adapter_id=telemetry_adapter_id,
            rtt_ms=profile_selector.handshake.get_avg_rtt_ms(),
        )

    # Always send current profile — UDP is lossy, so repeating ensures
    # the drone converges even if messages are dropped. The drone's
    # delta detection prevents redundant command execution.
    cur_idx = profile_selector.current_profile_idx
    cur_prof = profile_selector.current_profile
    if cur_prof is not None:
        generate_profile_message(cur_idx, cur_prof)



# ─── wfb-ng stats handling ───────────────────────────────────────────────────

def connect_to_server(host, port):
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.connect((host, port))
    print(f"\nReceiving wfb-ng stats from {host}:{port}")
    return sock


def handle_video_rx_stats(data):
    global best_rssi, best_snr, min_rssi, all_packets, fec_rec_packets, lost_packets
    global fec_k, fec_n, receiving_video, num_antennas
    global waiting_for_video_printed, video_rx_initial_message_printed
    global keyframe_request_code, keyframe_request_remaining

    packets = data.get("packets", {})
    all_packets = packets.get("all", [0])[0]
    receiving_video = (all_packets != 0)

    fec_rec_packets = packets.get("fec_rec", [0])[0]
    lost_packets = packets.get("lost", [0])[0]

    session = data.get("session") or {}
    fec_k = session.get("fec_k")
    fec_n = session.get("fec_n")

    rx_ant_stats = data.get("rx_ant_stats", [])
    num_antennas = len(rx_ant_stats)

    best_rssi = -101
    best_snr = 0
    min_rssi = 0
    for ant in rx_ant_stats:
        rssi = ant.get("rssi_avg")
        snr = ant.get("snr_avg")
        if rssi is not None:
            if rssi > best_rssi:
                best_rssi = rssi
            if min_rssi == 0 or rssi < min_rssi:
                min_rssi = rssi
        if snr is not None and snr > best_snr:
            best_snr = snr

    if receiving_video:
        if not video_rx_initial_message_printed:
            # Video stream just came back - force immediate handshake
            handshake.force_resync()
            print("\nReceiving video_rx stats\nWorking...")
            video_rx_initial_message_printed = True
        waiting_for_video_printed = False
    else:
        video_rx_initial_message_printed = False
        if not waiting_for_video_printed:
            print("\nWaiting for video_rx stats...")
            waiting_for_video_printed = True

    # Always drain handshake replies and tick, even during a video stall —
    # otherwise replies rot in the kernel RX buffer and we lose fresh FPS
    # data exactly when recovery would need it.
    now_ms = int(time.time() * 1000)
    _drain_handshake_replies(udp_socket, handshake)
    handshake.tick(now_ms)

    if telemetry_logger is not None and handshake.pop_session_changed():
        print("[HANDSHAKE] Drone session change — rotating telemetry log")
        telemetry_logger.new_session()

    if receiving_video:
        calculate_link()


def process_data_line(line):
    try:
        return json.loads(line)
    except json.JSONDecodeError:
        return None


def listen_for_data(sock):
    global waiting_for_video_printed, receiving_video
    waiting_for_video_printed = False
    sock.setblocking(False)
    buffer = bytearray()
    timeout_s = idr_send_interval_ms / 1000.0
    try:
        while True:
            ready, _, _ = select.select([sock], [], [], timeout_s)
            if sock in ready:
                try:
                    chunk = sock.recv(4096)
                except BlockingIOError:
                    chunk = b""
                if not chunk:
                    # Peer closed
                    break
                buffer.extend(chunk)
                while True:
                    nl = buffer.find(b"\n")
                    if nl < 0:
                        break
                    line = buffer[:nl].decode("utf-8", errors="replace")
                    del buffer[:nl + 1]
                    if not line:
                        continue
                    data = process_data_line(line)
                    if data is None:
                        continue
                    if data.get("type") == "rx" and data.get("id") == "video rx":
                        handle_video_rx_stats(data)
                    else:
                        receiving_video = False
            # Pace IDR repeats independent of wfb-ng cadence
            pump_keyframe_sender()
    except Exception as e:
        if verbose_mode:
            print(f"Error processing data: {e}")


def connect_to_wfb_stats():
    while True:
        sock = None
        try:
            sock = connect_to_server(host, port)
            listen_for_data(sock)
        except (socket.error, ConnectionRefusedError) as e:
            print(f"\n! Check VRX adapter(s)...\nNo connection to wfb-ng stats\n{e}\nRetrying in 3 seconds...")
        finally:
            if sock:
                sock.close()
            time.sleep(3)


