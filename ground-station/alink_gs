#!/usr/bin/env python3
"""
Ground station adaptive link controller.

Monitors wfb-ng signal metrics, selects transmission profiles using
multi-factor scoring (RF quality, packet loss, FEC pressure, antenna
diversity), and sends finalized profile parameters to the drone.
"""
import os
import socket
import json
import time
import argparse
import struct
import random
import string
import configparser
import math

# ─── 802.11n MCS reference tables (single spatial stream) ────────────────────

# Minimum SNR (dB) required for each MCS index
MCS_SNR_THRESHOLDS = [5, 8, 11, 14, 17, 20, 23, 26]

# PHY data rates in Mbps: [long_gi, short_gi]
PHY_RATES_20MHZ = [
    (6.5, 7.2),       # MCS 0 — BPSK 1/2
    (13.0, 14.4),      # MCS 1 — QPSK 1/2
    (19.5, 21.7),      # MCS 2 — QPSK 3/4
    (26.0, 28.9),      # MCS 3 — 16-QAM 1/2
    (39.0, 43.3),      # MCS 4 — 16-QAM 3/4
    (52.0, 57.8),      # MCS 5 — 64-QAM 2/3
    (58.5, 65.0),      # MCS 6 — 64-QAM 3/4
    (65.0, 72.2),      # MCS 7 — 64-QAM 5/6
]

PHY_RATES_40MHZ = [
    (13.5, 15.0),      # MCS 0
    (27.0, 30.0),      # MCS 1
    (40.5, 45.0),      # MCS 2
    (54.0, 60.0),      # MCS 3
    (81.0, 90.0),      # MCS 4
    (108.0, 120.0),    # MCS 5
    (121.5, 135.0),    # MCS 6
    (135.0, 150.0),    # MCS 7
]

# Default video frame rate (used when handshake not synced, and as fallback)
_VIDEO_FPS = 90

# WFB-NG MTU payload byte size (standard for OpenIPC)
MTU_PAYLOAD_BYTES = 1446

REQUIRED_SECTIONS = {
    'outgoing', 'wfb-ng', 'keyframe', 'profile selection', 'dynamic', 'gate'
}


# ─── Configuration helpers ───────────────────────────────────────────────────

def load_configuration(config_file):
    config = configparser.ConfigParser()
    read_files = config.read(config_file)
    if not read_files or not REQUIRED_SECTIONS.issubset(set(config.sections())):
        print("Error: Configuration file missing or invalid.")
        exit(1)
    return config




# ─── Telemetry logger ────────────────────────────────────────────────────────

class TelemetryLogger:
    """Append-only JSONL telemetry logger for ML training data collection.

    Logs one record per calculate_link() tick (~10Hz) with all link metrics,
    scoring sub-components, and selected profile parameters. Includes outcome
    labeling that tracks link quality in the ticks following a profile change.
    """

    def __init__(self, log_dir, rotate_mb=50, outcome_window=10, confirm_timeout=10):
        self.log_dir = log_dir
        self.rotate_bytes = rotate_mb * 1024 * 1024
        self.outcome_window = outcome_window
        self._file = None
        self._file_size = 0
        self._file_index = 0

        # Outcome tracking: ring buffer of loss_rate after profile changes
        self._outcome_ticks_remaining = 0
        self._outcome_losses = []
        self._outcome_change_record = None
        self._pending_outcomes = []  # completed outcome labels to flush

        # FEC confirmation state
        self._pending_confirm = None
        self._confirm_timeout_ticks = confirm_timeout
        self._confirm_ticks_waited = 0

        os.makedirs(log_dir, exist_ok=True)
        self._open_file()

    def _log_path(self):
        return os.path.join(self.log_dir, f"telemetry_{self._file_index}.jsonl")

    def _open_file(self):
        path = self._log_path()
        if os.path.exists(path):
            self._file_size = os.path.getsize(path)
        else:
            self._file_size = 0
        self._file = open(path, 'a')

    def _rotate_if_needed(self):
        if self._file_size >= self.rotate_bytes:
            self._file.close()
            self._file_index += 1
            self._open_file()

    def _write_record(self, record):
        line = json.dumps(record, separators=(',', ':')) + '\n'
        self._file.write(line)
        self._file.flush()
        self._file_size += len(line.encode('utf-8'))
        self._rotate_if_needed()

    def log(self, timestamp_ms, best_rssi, best_snr, min_rssi, num_antennas,
            all_packets, lost_packets, fec_rec_packets, fec_k, fec_n,
            loss_rate, fec_pressure, snr_ema, snr_slope,
            margin_current, margin_target, emergency,
            profile, profile_changed, adapter_id='default'):
        record = {
            'ts': timestamp_ms,
            'rssi': best_rssi,
            'snr': best_snr,
            'rssi_min': min_rssi,
            'ant': num_antennas,
            'pkt_all': all_packets,
            'pkt_lost': lost_packets,
            'pkt_fec': fec_rec_packets,
            'fec_k': fec_k,
            'fec_n': fec_n,
            'loss_rate': round(loss_rate, 6),
            'fec_pressure': round(fec_pressure, 4),
            'snr_ema': round(snr_ema, 2),
            'snr_slope': round(snr_slope, 3),
            'margin_cur': round(margin_current, 2),
            'margin_tgt': round(margin_target, 2),
            'emergency': emergency,
            'changed': profile_changed,
            'adapter': adapter_id,
        }
        if profile is not None:
            record['mcs'] = profile['mcs']
            record['gi'] = profile['gi']
            record['sel_fec_k'] = profile['fec_k']
            record['sel_fec_n'] = profile['fec_n']
            record['bitrate'] = profile['bitrate']
            record['power'] = profile['power']

        self._write_record(record)

        # Outcome tracking with FEC confirmation
        if profile_changed:
            # Finalize any pending outcome or confirmation
            self._finalize_outcome()
            self._pending_confirm = None
            # Start waiting for FEC confirmation
            if profile is not None:
                self._pending_confirm = {
                    'ts': timestamp_ms,
                    'fec_k': profile['fec_k'],
                    'fec_n': profile['fec_n'],
                }
                self._confirm_ticks_waited = 0

        # Check for FEC confirmation
        if self._pending_confirm is not None:
            self._confirm_ticks_waited += 1
            if (fec_k == self._pending_confirm['fec_k'] and
                    fec_n == self._pending_confirm['fec_n']):
                # Confirmed — start outcome window
                self._outcome_ticks_remaining = self.outcome_window
                self._outcome_losses = []
                self._outcome_change_record = {'ts': self._pending_confirm['ts']}
                self._pending_confirm = None
            elif self._confirm_ticks_waited >= self._confirm_timeout_ticks:
                # Timeout — discard, profile wasn't applied
                self._pending_confirm = None

        if self._outcome_ticks_remaining > 0:
            self._outcome_losses.append(loss_rate)
            self._outcome_ticks_remaining -= 1
            if self._outcome_ticks_remaining == 0:
                self._finalize_outcome()

    def _finalize_outcome(self):
        if not self._outcome_losses or self._outcome_change_record is None:
            return
        avg_loss = sum(self._outcome_losses) / len(self._outcome_losses)
        max_loss = max(self._outcome_losses)
        if max_loss > 0.05:
            label = 'bad'
        elif avg_loss > 0.02:
            label = 'marginal'
        else:
            label = 'good'
        outcome = {
            'type': 'outcome',
            'change_ts': self._outcome_change_record['ts'],
            'avg_loss': round(avg_loss, 6),
            'max_loss': round(max_loss, 6),
            'label': label,
            'ticks': len(self._outcome_losses),
        }
        self._write_record(outcome)
        self._outcome_change_record = None
        self._outcome_losses = []

    def close(self):
        self._finalize_outcome()
        self._pending_confirm = None
        if self._file:
            self._file.close()
            self._file = None


